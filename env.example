# ============================================================
#  CO2削減サポート 環境変数
# ============================================================

# --- 必須 ---

# PostgreSQL接続文字列（Neon等の無料PostgreSQL推奨。期限切れなし）
# 例: postgres://user:pass@ep-xxx.ap-southeast-1.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgres://user:password@host:5432/dbname

# Anthropic APIキー（見積診断のAI解析に使用。ブラウザには送信されません）
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxx

# セッション署名用シークレット（32文字以上のランダム文字列を推奨）
# 生成例: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=please-generate-a-long-random-string

# --- 任意 ---

# 本番環境では production に設定（セキュアCookie・HSTSが有効化されます）
NODE_ENV=production

# 使用するAIモデル（ご契約のモデルに合わせて設定）
ANTHROPIC_MODEL=claude-sonnet-5

# 新規会社登録の可否（false にすると登録フォームを無効化）
ALLOW_SIGNUP=true

# 見積書アップロード上限（MB）
MAX_FILE_MB=15

# ロゴ画像アップロード上限（MB）
MAX_LOGO_MB=2

# GX-ETS排出枠 参考価格（円/t-CO2）2026年度 政府公表値
ETS_PRICE_LOW=1700
ETS_PRICE_HIGH=4300

# ポート（Renderが自動設定。ローカルでは任意）
PORT=3000
